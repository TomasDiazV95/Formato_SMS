# Python cache / compiled artifacts
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs and temporary caches
*.log
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Frontend generated artifacts
react-frontend/node_modules/
react-frontend/dist/
react-frontend/.vite/

echo __pycache__/ >> .gitignore
echo *.pyc >> .gitignore